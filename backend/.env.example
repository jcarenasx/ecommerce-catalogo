NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public
JWT_ACCESS_SECRET=replace-with-a-long-random-secret

WEB_ORIGINS=https://www.tudominio.com,https://tudominio.com
COOKIE_NAME=ecom_access

# During the temporary Vercel -> production phase use:
# COOKIE_SAME_SITE=none
# COOKIE_SECURE=true
#
# After moving frontend to www.tudominio.com and backend to api.tudominio.com:
# COOKIE_SAME_SITE=lax
# COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
COOKIE_SECURE=true
COOKIE_DOMAIN=
# Use 1 if Node is behind Nginx or another reverse proxy.
# Use 0 if Node is exposed directly.
TRUST_PROXY=1

UPLOAD_DIRECTORY=uploads

AWS_REGION=us-east-1
S3_BUCKET_NAME=tu-bucket-de-media
S3_KEY_PREFIX=catalog
S3_UPLOAD_MAX_BYTES=5242880
S3_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/avif
S3_PUBLIC_URL_BASE=https://media.tudominio.com
S3_ENDPOINT=
