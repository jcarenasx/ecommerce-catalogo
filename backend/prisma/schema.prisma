generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  phone        String?
  passwordHash String
  role         UserRole   @default(USER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  cartItems    CartItem[]
  orders       Order[]
}

model Product {
  model                      String     @id @map("modelo")
  name                       String
  sku                        String?    @map("sku")
  size                       String?    @map("talla")
  color                      String?    @map("color")
  category                   String?    @map("categoria")
  brand                      String?    @map("marca")
  priceCents                 Int?
  paymentLinkWithShipping    String?
  paymentLinkWithoutShipping String?
  images                     String[]   @default([])
  active                     Boolean    @default(true)
  createdAt                  DateTime   @default(now())
  updatedAt                  DateTime   @updatedAt
  availabilityTagId          String?    @map("availability_tag_id")
  availabilityTag            AvailabilityTag? @relation(fields: [availabilityTagId], references: [id])

  cartItems                  CartItem[]
}

model AvailabilityTag {
  id        String      @id @default(cuid())
  name      String      @unique
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  products  Product[]
}

model CartItem {
  id         String   @id @default(cuid())
  userId     String
  productModel String
  quantity   Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productModel], references: [model], onDelete: Cascade)

  @@unique([userId, productModel])
}

model Order {
  id         String      @id @default(cuid())
  userId     String
  status     OrderStatus @default(PENDING)
  totalCents Int
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      OrderItem[]
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  Int
  name       String
  priceCents Int
  quantity   Int
  createdAt  DateTime @default(now())

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String
  createdAt DateTime @default(now())
}

enum UserRole {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
}
